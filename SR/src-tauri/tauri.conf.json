{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SR",
  "version": "0.1.0",
  "identifier": "com.guolicheng.sr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1424",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SR",
        "width": 336,
        "height": 400,
        "minWidth": 336,
        "minHeight": 400,
        "maxWidth": 336,
        "maxHeight": 400,
        "resizable": false,
        "center": false,
        "decorations": false,
        "shadow": false,
        "create": false,
        "visible": false
      },
      {
        "label": "sr-overlay",
        "title": "",
        "url": "overlay.html",
        "width": 336,
        "height": 52,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false,
        "shadow": false,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "resources/streaming_asr.py": "resources/streaming_asr.py",
      "resources/models/": "models/",
      "resources/python/": "python/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
